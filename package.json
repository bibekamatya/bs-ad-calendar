{
  "name": "bs-ad-calendar",
  "version": "1.0.0",
  "description": "A modern React calendar component supporting both Bikram Sambat (BS) and Gregorian (AD) calendars",
  "type": "module",
  "main": "./dist/bs-ad-calendar.umd.cjs",
  "module": "./dist/bs-ad-calendar.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/bs-ad-calendar.js",
      "require": "./dist/bs-ad-calendar.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "keywords": [
    "react",
    "calendar",
    "nepali",
    "bikram-sambat",
    "date-picker",
    "bs",
    "ad"
  ],
  "author": "Bibek Amatya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bibekamatya/bs-ad-calendar.git"
  },
  "dependencies": {
    "nepali-datetime": "^1.5.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
